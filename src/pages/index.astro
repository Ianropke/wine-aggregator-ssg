---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const wines = await getCollection('wines');
// Sort by QPR descending
wines.sort((a, b) => b.data.qpr - a.data.qpr);
---

<Layout title="Wine Price Aggregator - QPR Data">
  <div class="mb-12 text-center">
    <h1 class="text-4xl font-black uppercase mb-4">Algoritmisk Vinkuration</h1>
    <p class="text-xl text-gray-600">Oplev fremtidens vinanbefalinger. Sorteret efter ren Quality-Price Ratio.</p>
  </div>
  
  <div class="mb-12">
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet">
    <script src="/pagefind/pagefind-ui.js" is:inline></script>
    <div id="search" class="w-full"></div>
    <script is:inline>
        window.addEventListener('DOMContentLoaded', (event) => {
            new PagefindUI({ element: "#search", showSubResults: true });
        });
    </script>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    {wines.map(wine => (
      <a href={`/wines/${wine.data.id}`} class="block group">
        <article class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 transition duration-300 group-hover:shadow-md group-hover:border-gray-300">
          <div class="flex justify-between items-start mb-4">
            <h2 class="text-2xl font-bold text-gray-900 leading-tight">{wine.data.title}</h2>
            <span class="bg-red-50 text-red-700 font-black px-3 py-1 rounded-full">{wine.data.points} pts</span>
          </div>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="bg-gray-100 text-gray-700 text-sm px-2 py-1 rounded">{wine.data.region}</span>
            <span class="bg-gray-100 text-gray-700 text-sm px-2 py-1 rounded">{wine.data.vintage}</span>
          </div>
          <div class="flex justify-between items-end mt-6 pt-4 border-t border-gray-50">
            <div>
              <p class="text-sm text-gray-500 uppercase tracking-wider font-bold">Pris</p>
              <p class="text-xl font-black">{wine.data.price} kr.</p>
            </div>
            <div class="text-right">
              <p class="text-sm text-gray-500 uppercase tracking-wider font-bold">QPR Score</p>
              <p class="text-xl font-black text-green-600">{wine.data.qpr}</p>
            </div>
          </div>
        </article>
      </a>
    ))}
  </div>
</Layout>
