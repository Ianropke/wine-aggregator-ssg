---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import VibeLogoBadge from '../components/VibeLogoBadge.astro';

const wines = await getCollection('wines');
// Sort by QPR descending
wines.sort((a, b) => b.data.qpr - a.data.qpr);

const categoriesInfo: Record<string, {emoji: string, from: string, to: string}> = {
  "Elektrisk, Sprød & Tørstslukkende": { emoji: "⚡", from: "from-[#FF6B6B]", to: "to-[#FF8E53]" },
  "Blød, Varm & Omfavnende": { emoji: "🧸", from: "from-blue-500", to: "to-cyan-400" },
  "Netflix & Chill": { emoji: "🍿", from: "from-purple-500", to: "to-indigo-400" },
  "Saftig, Vild & Utæmmet": { emoji: "🌪️", from: "from-orange-500", to: "to-red-500" },
  "Dyb, Forførende & Intens": { emoji: "🍷", from: "from-rose-600", to: "to-pink-500" },
  "Tung Bas & Store Armbevægelser": { emoji: "🔊", from: "from-fuchsia-600", to: "to-pink-500" }
};

// Group by category, max 4 wines per category
const groupedWines = Object.keys(categoriesInfo).map(category => {
  const allWinesInCategory = wines.filter(w => w.data.vibe_category === category);
  return {
    category,
    slug: category.toLowerCase().replace(/[^a-z0-9]+/g, '-'),
    info: categoriesInfo[category],
    wines: allWinesInCategory.slice(0, 4),
    totalCount: allWinesInCategory.length
  };
}).filter(g => g.wines.length > 0);
---

<Layout title="VibeWine - Drik Din Vibe">
  <div class="mb-16 text-center max-w-2xl mx-auto reveal">
    <img src="/hero.jpg" alt="VibeWine Energy" class="w-full max-w-lg mx-auto mb-10 rounded-3xl shadow-xl hover:scale-[1.02] transition-transform duration-500" />
    <h1 class="text-4xl md:text-6xl font-['Outfit',sans-serif] font-black text-[#111827] mb-6 tracking-tight">Drop Snobberiet.</h1>
    <p class="text-xl text-gray-600 font-light leading-relaxed mb-10">Vi anmelder ikke terroir eller mikroklima. Vi anmelder <span class="font-bold text-[#FF6B6B]">Vibes</span>.</p>
    
    <div class="w-full max-w-2xl mx-auto">
      <link href="/pagefind/pagefind-ui.css" rel="stylesheet">
      <script src="/pagefind/pagefind-ui.js" is:inline></script>
      <div id="search" class="w-full"></div>
      <style is:global>
        .pagefind-ui__search-input { border-radius: 9999px !important; font-family: 'Inter', sans-serif !important; border-color: #FFE4E8 !important; background: #FFF9FA !important; padding: 1.5rem !important; font-weight: 500 !important; }
        .pagefind-ui__button { border-radius: 9999px !important; background-color: #FF6B6B !important; color: white !important; font-family: 'Outfit', sans-serif !important; font-weight: 700 !important; padding: 0 2rem !important; }
        .reveal { opacity: 0; transform: translateY(30px); transition: all 0.8s ease-out; }
        .reveal.active { opacity: 1; transform: translateY(0); }
      </style>
      <script is:inline>
          window.addEventListener('DOMContentLoaded', (event) => {
              new PagefindUI({ element: "#search", showSubResults: true, showImages: false });
              
              const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                  if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                  }
                });
              }, { threshold: 0.1 });
              
              document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
          });
      </script>
    </div>
  </div>
  
  <div class="mb-24 space-y-20">
    {groupedWines.map(group => (
      <section class="reveal">
        <div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div class="flex items-center gap-4 flex-grow">
            <h2 class="text-3xl font-['Outfit'] font-black text-[#111827] capitalize whitespace-nowrap">{group.info.emoji} {group.category}</h2>
            <div class="h-px bg-gray-200 flex-grow hidden md:block"></div>
          </div>
          {group.totalCount > 4 && (
            <a href={`/vibes/${group.slug}`} class="shrink-0 text-sm font-bold text-[#FF6B6B] bg-[#FFF9FA] hover:bg-[#FF6B6B] hover:text-white transition-colors px-4 py-2 rounded-full border border-[#FF6B6B]/30 uppercase tracking-widest flex items-center gap-1">
              Se alle {group.totalCount} <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </a>
          )}
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {group.wines.map(wine => (
            <a href={`/wines/${wine.data.id}`} class="block group">
              <article class="bg-white p-8 rounded-3xl border-2 border-transparent transition-all duration-300 hover:border-[#FF6B6B] hover:shadow-[0_20px_50px_-12px_rgba(255,107,107,0.2)] hover:-translate-y-2 flex flex-col h-full relative overflow-hidden reveal">
                <div class={`absolute top-0 left-0 w-full h-2 bg-gradient-to-r ${group.info.from} ${group.info.to} transform origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-500 ease-out`}></div>
                <div class="mb-6 flex-grow">
                  <h3 class="text-2xl font-['Outfit',sans-serif] font-bold text-[#111827] mb-3 leading-tight group-hover:text-[#FF6B6B] transition-colors">{wine.data.title}</h3>
                  <div class="flex flex-wrap items-center gap-2 text-sm text-gray-500 font-medium">
                    <span class="bg-[#FFF9FA] px-3 py-1 rounded-full text-[#FF6B6B]">{wine.data.region}</span>
                    <span>{wine.data.vintage}</span>
                  </div>
                </div>
                
                <div class="flex justify-between items-end pt-6 border-t border-[#FFE4E8]">
                  <div>
                    <p class="text-xs font-bold uppercase tracking-[0.2em] text-gray-400 mb-1">Pris</p>
                    <p class="text-2xl font-black text-[#111827]">{Math.round(wine.data.price)} <span class="text-sm font-medium text-gray-500">kr.</span></p>
                    {wine.data.bundle_size && wine.data.bundle_size > 1 && (
                      <p class="text-[10px] text-gray-400 uppercase tracking-widest mt-1">Ved {wine.data.bundle_size} flasker</p>
                    )}
                  </div>
                  <div class="text-right">
                    <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#FF6B6B] mb-1">Vibe Score</p>
                    <p class="text-2xl font-['Outfit',sans-serif] font-black text-[#111827]">{wine.data.points} <span class="text-sm font-medium text-gray-500">pts</span></p>
                  </div>
                </div>
              </article>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>

  <section class="max-w-4xl mx-auto bg-[#111827] text-white p-10 md:p-16 rounded-3xl mb-16 relative overflow-hidden shadow-2xl reveal">
    <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-[#FF6B6B] to-[#FF8E53] rounded-full blur-3xl opacity-20 -translate-y-1/2 translate-x-1/3"></div>
    <div class="relative z-10">
      <h2 class="text-4xl md:text-5xl font-['Outfit'] font-black mb-6 text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-400">Hvad er VibeWine?</h2>
      
      <div class="prose prose-lg prose-invert max-w-none">
        <p class="text-xl font-light leading-relaxed mb-6">
          Jeg har mange års erfaring med vin, men jeg har altid savnet et sted, hvor man bare kunne få en <strong class="text-[#FF6B6B] font-bold">kort, usnobbet holdning</strong> til, hvad der er i glasset. VibeWine er mit opgør med evindeligt snak om terroir, mikroklima og noter af "våd skovbund". Her får du det direkte og råt: Hvad er viben?
        </p>
        
        <div class="bg-white/5 rounded-2xl p-8 border border-white/10 mt-8">
          <h3 class="text-2xl font-['Outfit'] font-bold text-white mb-4">Vibe Scoren & Værdi-Indexet</h3>
          <p class="font-light leading-relaxed mb-4 text-gray-300">
            <strong>Vibe Scoren</strong> er min nådesløse dom over vinens energi. Den uddeles benhårdt. En dyr vin får ikke automatisk topkarakter her – faktisk er der indbygget risiko for at de dyre skuffer, mens de billige overrasker.
          </p>
          <p class="font-light leading-relaxed text-gray-300">
            <strong>Værdi-Indexet (QPR)</strong> fortæller dig, hvor meget smæk du får for skillingen. Indexet udregnes algoritmisk og er baseret <em>præcis på den pris, jeg betalte</em> den dag, jeg smagte vinen. Hvis en vin har et tårnhøjt Værdi-Index, er det et absolut røverkøb.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
