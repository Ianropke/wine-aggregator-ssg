---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const wines = await getCollection('wines');
wines.sort((a, b) => b.data.qpr - a.data.qpr); // sort by QPR

const categoriesInfo: Record<string, {emoji: string, from: string, to: string}> = {
  "Elektrisk, Sprød & Tørstslukkende": { emoji: "⚡", from: "from-[#FF6B6B]", to: "to-[#FF8E53]" },
  "Blød, Varm & Omfavnende": { emoji: "🧸", from: "from-blue-500", to: "to-cyan-400" },
  "Netflix & Chill": { emoji: "🍿", from: "from-purple-500", to: "to-indigo-400" },
  "Saftig, Vild & Utæmmet": { emoji: "🌪️", from: "from-orange-500", to: "to-red-500" },
  "Dyb, Forførende & Intens": { emoji: "🍷", from: "from-rose-600", to: "to-pink-500" },
  "Tung Bas & Store Armbevægelser": { emoji: "🔊", from: "from-fuchsia-600", to: "to-pink-500" }
};
---

<Layout title="VibeWine - Drik Din Vibe" maxWidth="max-w-7xl">
  <!-- Ny Hero Sektion -->
  <div class="relative mb-20 rounded-3xl overflow-hidden bg-gradient-to-br from-[#FFF0F2] to-[#FFE0E6] border border-[#FFE4E8] px-8 py-20 md:py-32 text-center shadow-sm reveal">
    <div class="absolute inset-0 bg-white/40 backdrop-blur-[2px]"></div>
    <div class="absolute -top-32 -left-32 w-96 h-96 bg-[#FF6B6B] rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>
    <div class="absolute -bottom-32 -right-32 w-96 h-96 bg-[#FF8E53] rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>
    
    <div class="relative z-10 max-w-3xl mx-auto">
      <h1 class="text-5xl md:text-7xl font-['Outfit',sans-serif] font-black text-[#111827] mb-8 tracking-tight leading-tight">Find vinen der matcher din vibe</h1>
      <p class="text-xl md:text-2xl text-gray-600 font-light leading-relaxed mb-10">Vi anmelder ikke terroir eller mikroklima. Vi anmelder <span class="font-bold text-[#FF6B6B]">Vibes</span>.</p>
      
      <div class="w-full max-w-xl mx-auto">
        <link href="/pagefind/pagefind-ui.css" rel="stylesheet">
        <script src="/pagefind/pagefind-ui.js" is:inline></script>
        <div id="search" class="w-full"></div>
      </div>
    </div>
  </div>
  
  <div class="flex flex-col lg:flex-row gap-12 mb-24">
    <!-- Sidebar / Filters -->
    <aside class="w-full lg:w-1/4 shrink-0">
      <div class="bg-white rounded-[2rem] shadow-sm border border-[#FFE4E8] p-8 sticky top-32 max-h-[calc(100vh-8rem)] overflow-y-auto sidebar-scroll">
        <h2 class="text-2xl font-['Outfit'] font-black text-[#111827] mb-8">Filtrér Vibes</h2>
        
        <!-- Kategorier -->
        <div class="mb-8">
          <h3 class="text-sm font-bold uppercase tracking-widest text-gray-400 mb-4">Kategorier</h3>
          <div class="space-y-3">
            {Object.entries(categoriesInfo).map(([cat, info]) => (
              <label class="flex items-start gap-3 cursor-pointer group">
                <input type="checkbox" class="filter-category mt-1 w-5 h-5 rounded border-gray-300 text-[#FF6B6B] focus:ring-[#FF6B6B]" value={cat} />
                <span class="text-gray-700 font-medium group-hover:text-[#FF6B6B] transition-colors">{info.emoji} {cat}</span>
              </label>
            ))}
          </div>
        </div>

        <!-- Pris -->
        <div class="mb-8">
          <h3 class="text-sm font-bold uppercase tracking-widest text-gray-400 mb-4">Pris</h3>
          <div class="space-y-3">
            <label class="flex items-center gap-3 cursor-pointer group">
              <input type="checkbox" class="filter-price w-5 h-5 rounded border-gray-300 text-[#FF6B6B] focus:ring-[#FF6B6B]" value="0-80" />
              <span class="text-gray-700 font-medium group-hover:text-[#FF6B6B] transition-colors">Under 80 kr.</span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer group">
              <input type="checkbox" class="filter-price w-5 h-5 rounded border-gray-300 text-[#FF6B6B] focus:ring-[#FF6B6B]" value="80-150" />
              <span class="text-gray-700 font-medium group-hover:text-[#FF6B6B] transition-colors">80 - 150 kr.</span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer group">
              <input type="checkbox" class="filter-price w-5 h-5 rounded border-gray-300 text-[#FF6B6B] focus:ring-[#FF6B6B]" value="150-300" />
              <span class="text-gray-700 font-medium group-hover:text-[#FF6B6B] transition-colors">150 - 300 kr.</span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer group">
              <input type="checkbox" class="filter-price w-5 h-5 rounded border-gray-300 text-[#FF6B6B] focus:ring-[#FF6B6B]" value="300-100000" />
              <span class="text-gray-700 font-medium group-hover:text-[#FF6B6B] transition-colors">Over 300 kr.</span>
            </label>
          </div>
        </div>
        
        <!-- Vibe Score -->
        <div class="mb-8">
          <h3 class="text-sm font-bold uppercase tracking-widest text-gray-400 mb-4">Vibe Score</h3>
          <div class="space-y-3">
            <label class="flex items-center gap-3 cursor-pointer group">
              <input type="checkbox" class="filter-score w-5 h-5 rounded border-gray-300 text-[#FF6B6B] focus:ring-[#FF6B6B]" value="95-100" />
              <span class="text-gray-700 font-medium group-hover:text-[#FF6B6B] transition-colors">Legendarisk (95-100)</span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer group">
              <input type="checkbox" class="filter-score w-5 h-5 rounded border-gray-300 text-[#FF6B6B] focus:ring-[#FF6B6B]" value="90-94" />
              <span class="text-gray-700 font-medium group-hover:text-[#FF6B6B] transition-colors">Fremragende (90-94)</span>
            </label>
          </div>
        </div>

        <button id="reset-filters" class="w-full py-3 px-4 bg-[#FFF9FA] text-[#FF6B6B] rounded-xl font-bold uppercase tracking-widest text-sm hover:bg-[#FF6B6B] hover:text-white transition-colors border border-[#FF6B6B]/20">
          Nulstil Filtre
        </button>
      </div>
    </aside>

    <!-- Product Grid -->
    <main class="w-full lg:w-3/4">
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4 reveal">
        <h2 class="text-3xl font-['Outfit'] font-black text-[#111827]">Vinkatalog</h2>
        <div class="flex items-center gap-4 w-full sm:w-auto">
          <div class="relative w-full sm:w-48">
            <select id="sort-order" class="w-full appearance-none bg-white border border-[#FFE4E8] text-gray-700 py-2.5 px-4 pr-8 rounded-full font-medium focus:outline-none focus:ring-2 focus:ring-[#FF6B6B] focus:border-transparent cursor-pointer">
              <option value="qpr-desc">Bedste Værdi</option>
              <option value="score-desc">Højeste Vibe Score</option>
              <option value="price-asc">Billigste Først</option>
              <option value="price-desc">Dyreste Først</option>
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-gray-500">
              <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
            </div>
          </div>
          <span id="result-count" class="shrink-0 text-gray-500 font-bold bg-[#FFF9FA] px-4 py-2.5 rounded-full border border-[#FFE4E8]">{wines.length} vine</span>
        </div>
      </div>

      <div id="wine-grid" class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {wines.map(wine => {
          const info = wine.data.vibe_category && categoriesInfo[wine.data.vibe_category] ? categoriesInfo[wine.data.vibe_category] : { emoji: "🍷", from: "from-[#FF6B6B]", to: "to-[#FF8E53]" };
          return (
            <a href={`/wines/${wine.data.id}`} 
               class="wine-card block group reveal" 
               data-category={wine.data.vibe_category} 
               data-price={wine.data.price} 
               data-score={wine.data.points} 
               data-qpr={wine.data.qpr}>
              <article class="bg-white p-8 rounded-3xl border-2 border-transparent transition-all duration-300 hover:border-[#FF6B6B] hover:shadow-[0_20px_50px_-12px_rgba(255,107,107,0.2)] hover:-translate-y-2 flex flex-col h-full relative overflow-hidden">
                <div class={`absolute top-0 left-0 w-full h-2 bg-gradient-to-r ${info.from} ${info.to} transform origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-500 ease-out`}></div>
                
                <div class="mb-4">
                  <span class="inline-flex items-center gap-2 bg-[#FFF9FA] text-[#111827] px-3 py-1 rounded-full text-xs font-bold border border-[#FFE4E8] mb-4">
                    <span>{info.emoji}</span> {wine.data.vibe_category}
                  </span>
                </div>

                <div class="mb-6 flex-grow">
                  <h3 class="text-2xl font-['Outfit',sans-serif] font-bold text-[#111827] mb-3 leading-tight group-hover:text-[#FF6B6B] transition-colors">{wine.data.title}</h3>
                  <div class="flex flex-wrap items-center gap-2 text-sm text-gray-500 font-medium">
                    <span class="text-[#FF6B6B] font-bold">{wine.data.region}</span>
                    <span class="w-1 h-1 rounded-full bg-gray-300"></span>
                    <span>{wine.data.vintage}</span>
                  </div>
                </div>
                
                <div class="mt-4 pt-6 border-t border-[#FFE4E8] flex flex-col gap-4">
                  <p class="text-sm font-medium text-gray-600 leading-relaxed italic">
                    "{wine.body ? wine.body.replace(/^>\s*/, '').trim() : ''}"
                  </p>
                  <div class="flex justify-between items-end bg-[#FFF9FA] p-4 rounded-2xl border border-[#FFE4E8]">
                    <div>
                      <p class="text-xs font-bold uppercase tracking-[0.2em] text-gray-400 mb-1">Pris</p>
                      <p class="text-2xl font-['Outfit',sans-serif] font-black text-[#111827]">{Math.round(wine.data.price)} <span class="text-sm font-medium text-gray-500">kr.</span></p>
                      {wine.data.bundle_size && wine.data.bundle_size > 1 && (
                        <p class="text-[10px] text-gray-400 uppercase tracking-widest mt-1">Ved {wine.data.bundle_size} flasker</p>
                      )}
                    </div>
                    <div class="text-right">
                      <p class="text-xs font-bold uppercase tracking-[0.2em] text-gray-400 mb-1">Vibe Score</p>
                      <p class="text-2xl font-['Outfit',sans-serif] font-black text-[#111827]">{wine.data.points} <span class="text-sm font-medium text-[#FF6B6B]">pts</span></p>
                    </div>
                  </div>
                </div>
              </article>
            </a>
          );
        })}
      </div>
      
      <div id="no-results" class="hidden text-center py-24 bg-[#FFF9FA] rounded-[2rem] border border-[#FFE4E8]">
        <p class="text-4xl mb-4">🍷</p>
        <h3 class="text-2xl font-['Outfit'] font-bold text-[#111827] mb-2">Ingen vine matcher dit vibe-tjek</h3>
        <p class="text-gray-500">Prøv at justere dine filtre for at se flere resultater.</p>
        <button onclick="document.getElementById('reset-filters').click()" class="mt-8 px-6 py-3 bg-[#FF6B6B] text-white rounded-full font-bold uppercase tracking-widest text-sm hover:bg-[#ff5252] transition-colors">
          Nulstil Filtre
        </button>
      </div>
    </main>
  </div>

  <style is:global>
    .pagefind-ui__search-input { border-radius: 9999px !important; font-family: 'Inter', sans-serif !important; border-color: #FFE4E8 !important; background: #FFF9FA !important; padding: 1.5rem !important; font-weight: 500 !important; }
    .pagefind-ui__button { border-radius: 9999px !important; background-color: #FF6B6B !important; color: white !important; font-family: 'Outfit', sans-serif !important; font-weight: 700 !important; padding: 0 2rem !important; }
    .reveal { opacity: 0; transform: translateY(30px); transition: all 0.8s ease-out; }
    .reveal.active { opacity: 1; transform: translateY(0); }
    /* Fix for Tailwind preflight hiding checkboxes */
    input[type="checkbox"] {
      appearance: auto !important;
      accent-color: #FF6B6B;
      cursor: pointer;
    }
    
    /* Elegant thin scrollbar for sidebar */
    .sidebar-scroll::-webkit-scrollbar {
      width: 4px;
    }
    .sidebar-scroll::-webkit-scrollbar-track {
      background: transparent; 
    }
    .sidebar-scroll::-webkit-scrollbar-thumb {
      background: #FFE4E8; 
      border-radius: 10px;
    }
    .sidebar-scroll::-webkit-scrollbar-thumb:hover {
      background: #FF6B6B; 
    }
    .sidebar-scroll {
      scrollbar-width: thin;
      scrollbar-color: #FFE4E8 transparent;
    }
  </style>

  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      // Setup Pagefind
      try {
        new PagefindUI({ element: "#search", showSubResults: true, showImages: false });
      } catch (e) {
        console.error("PagefindUI error:", e);
      }
      
      // Setup Reveal Animations
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
          }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

      // Filtering Logic
      const wineGrid = document.getElementById('wine-grid');
      const wineCards = Array.from(document.querySelectorAll('.wine-card'));
      const catCheckboxes = document.querySelectorAll('.filter-category');
      const priceCheckboxes = document.querySelectorAll('.filter-price');
      const scoreCheckboxes = document.querySelectorAll('.filter-score');
      const noResults = document.getElementById('no-results');
      const resultCount = document.getElementById('result-count');
      const resetButton = document.getElementById('reset-filters');
      const sortOrder = document.getElementById('sort-order');

      function filterAndSortWines() {
        // 1. FILTERING
        const activeCats = Array.from(catCheckboxes).filter(cb => cb.checked).map(cb => cb.value);
        
        const activePrices = Array.from(priceCheckboxes).filter(cb => cb.checked).map(cb => {
          const [min, max] = cb.value.split('-').map(Number);
          return { min, max };
        });

        const activeScores = Array.from(scoreCheckboxes).filter(cb => cb.checked).map(cb => {
          const [min, max] = cb.value.split('-').map(Number);
          return { min, max };
        });

        let visibleCount = 0;
        let visibleCards = [];

        wineCards.forEach(card => {
          const category = card.dataset.category;
          const price = parseFloat(card.dataset.price);
          const score = parseFloat(card.dataset.score);

          let matchCat = activeCats.length === 0 || activeCats.includes(category);
          let matchPrice = activePrices.length === 0 || activePrices.some(range => price >= range.min && price <= range.max);
          let matchScore = activeScores.length === 0 || activeScores.some(range => score >= range.min && score <= range.max);

          if (matchCat && matchPrice && matchScore) {
            card.style.display = 'block';
            visibleCards.push(card);
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        // 2. SORTING
        const sortVal = sortOrder.value;
        visibleCards.sort((a, b) => {
          const priceA = parseFloat(a.dataset.price);
          const priceB = parseFloat(b.dataset.price);
          const scoreA = parseFloat(a.dataset.score);
          const scoreB = parseFloat(b.dataset.score);
          const qprA = parseFloat(a.dataset.qpr);
          const qprB = parseFloat(b.dataset.qpr);
          
          if (sortVal === 'price-asc') return priceA - priceB;
          if (sortVal === 'price-desc') return priceB - priceA;
          if (sortVal === 'score-desc') return scoreB - scoreA;
          if (sortVal === 'qpr-desc') return qprB - qprA;
          return 0;
        });

        // Append sorted cards back to grid
        visibleCards.forEach(card => wineGrid.appendChild(card));

        // Update UI
        resultCount.textContent = `${visibleCount} vine`;
        if (visibleCount === 0) {
          noResults.classList.remove('hidden');
        } else {
          noResults.classList.add('hidden');
        }
      }

      // Add event listeners
      [...catCheckboxes, ...priceCheckboxes, ...scoreCheckboxes].forEach(cb => {
        cb.addEventListener('change', filterAndSortWines);
      });
      sortOrder.addEventListener('change', filterAndSortWines);

      // Reset
      resetButton.addEventListener('click', () => {
        [...catCheckboxes, ...priceCheckboxes, ...scoreCheckboxes].forEach(cb => cb.checked = false);
        sortOrder.value = 'qpr-desc'; // default
        filterAndSortWines();
      });
    });
  </script>
</Layout>
