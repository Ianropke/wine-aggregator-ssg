---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const wines = await getCollection('wines');
// Sort by QPR descending
wines.sort((a, b) => b.data.qpr - a.data.qpr);
---

<Layout title="Wine Price Aggregator - QPR Data">
  <div class="mb-16 text-center max-w-2xl mx-auto">
    <img src="/hero.jpg" alt="Vinglas og drueklase akvarel" class="w-full max-w-sm mx-auto mb-8 mix-blend-multiply opacity-90" />
    <h1 class="text-4xl md:text-5xl font-['Playfair_Display',serif] font-normal text-[#2C2A29] mb-4">Din Personlige Sommelier</h1>
    <p class="text-lg text-gray-500 font-light leading-relaxed">Håndplukkede vine, udvalgt til at give dig den mest udsøgte oplevelse til prisen.</p>
  </div>
  
  <div class="mb-16 border-b border-t border-[#E8E4D9] py-8">
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet">
    <script src="/pagefind/pagefind-ui.js" is:inline></script>
    <div id="search" class="w-full max-w-2xl mx-auto"></div>
    <style is:global>
      .pagefind-ui__search-input { border-radius: 0 !important; font-family: 'Lato', sans-serif !important; border-color: #E8E4D9 !important; background: transparent !important; }
      .pagefind-ui__button { border-radius: 0 !important; background-color: #722F37 !important; color: white !important; font-family: 'Lato', sans-serif !important; }
    </style>
    <script is:inline>
        window.addEventListener('DOMContentLoaded', (event) => {
            new PagefindUI({ element: "#search", showSubResults: true, showImages: false });
        });
    </script>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
    {wines.map(wine => (
      <a href={`/wines/${wine.data.id}`} class="block group">
        <article class="bg-white p-8 border border-[#E8E4D9] transition duration-500 hover:border-[#722F37] hover:shadow-[0_10px_40px_-15px_rgba(114,47,55,0.15)] flex flex-col h-full">
          <div class="mb-6 flex-grow">
            <h2 class="text-2xl font-['Playfair_Display',serif] text-[#2C2A29] mb-2 leading-tight group-hover:text-[#722F37] transition-colors">{wine.data.title}</h2>
            <div class="flex items-center gap-2 text-sm text-gray-500 font-light">
              <span>{wine.data.region}</span>
              <span class="w-1 h-1 rounded-full bg-gray-300"></span>
              <span>{wine.data.vintage}</span>
            </div>
          </div>
          
          <div class="flex justify-between items-end pt-6 border-t border-[#FAF9F6]">
            <div>
              <p class="text-xs uppercase tracking-widest text-gray-400 mb-1">Pris</p>
              <p class="text-xl font-light text-[#2C2A29]">{Math.round(wine.data.price)} <span class="text-sm">kr.</span></p>
            </div>
            <div class="text-right">
              <p class="text-xs uppercase tracking-widest text-[#722F37] mb-1">Anbefaling</p>
              <p class="text-xl font-['Playfair_Display',serif] italic text-[#2C2A29]">{wine.data.points} pts</p>
            </div>
          </div>
        </article>
      </a>
    ))}
  </div>
</Layout>
