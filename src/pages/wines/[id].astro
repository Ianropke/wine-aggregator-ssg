---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProConMatrix from '../../components/ProConMatrix.astro';
import SonicSeasoning from '../../components/SonicSeasoning.astro';

export async function getStaticPaths() {
  const wines = await getCollection('wines');
  return wines.map(wine => ({
    params: { id: wine.data.id },
    props: { wine },
  }));
}

const { wine } = Astro.props;
const { Content } = await render(wine);

// Bygger JSON-LD schema (Rule 10)
const schema = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": wine.data.title,
  "description": `Vinanmeldelse af ${wine.data.title} fra ${wine.data.region}. QPR: ${wine.data.qpr}.`,
  "offers": {
    "@type": "Offer",
    "priceCurrency": "DKK",
    "price": wine.data.price,
    "availability": "https://schema.org/InStock"
  },
  "review": {
    "@type": "Review",
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": wine.data.points,
      "bestRating": 100,
      "worstRating": 50
    },
    "author": {
      "@type": "Organization",
      "name": "Wine Price Aggregator"
    },
    "positiveNotes": {
      "@type": "ItemList",
      "itemListElement": wine.data.pros.map((p: string, i: number) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": p
      }))
    },
    "negativeNotes": {
      "@type": "ItemList",
      "itemListElement": wine.data.cons.map((c: string, i: number) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": c
      }))
    }
  }
};
---

<Layout title={`${wine.data.title} - VibeWine`} description={wine.data.vibe_description} schema={schema}>
  <article class="max-w-4xl mx-auto bg-white rounded-[2rem] shadow-sm border border-[#FFE4E8] p-8 md:p-16 mb-16 relative overflow-hidden">
    <!-- Decorative gradient orb -->
    <div class="absolute -top-32 -right-32 w-64 h-64 bg-[#FF6B6B] rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>
    <div class="absolute -bottom-32 -left-32 w-64 h-64 bg-[#FF8E53] rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>

    <header class="text-center mb-16 relative z-10">
      <div class="inline-flex items-center gap-3 text-sm font-bold tracking-widest uppercase text-[#FF6B6B] mb-8 bg-[#FFF9FA] px-6 py-2 rounded-full">
        <span>{wine.data.region}</span>
        <span class="w-1.5 h-1.5 rounded-full bg-[#FF6B6B] opacity-50"></span>
        <span>{wine.data.vintage}</span>
      </div>
      
      <h1 class="text-5xl md:text-7xl font-['Outfit',sans-serif] font-black text-[#111827] mb-12 leading-tight tracking-tight">{wine.data.title}</h1>
      
      <div class="flex flex-wrap justify-center gap-6 md:gap-16 items-center bg-[#FFF9FA] py-8 rounded-3xl border border-[#FFE4E8]">
        <div class="text-center">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-gray-400 mb-2">Pris</p>
          <p class="text-4xl font-black text-[#111827]">{Math.round(wine.data.price)} <span class="text-xl font-medium text-gray-500">kr.</span></p>
        </div>
        <div class="hidden md:block w-px h-16 bg-[#FFE4E8]"></div>
        <div class="text-center">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-gray-400 mb-2">Vibe Score</p>
          <p class="text-4xl font-['Outfit',sans-serif] font-black text-[#FF6B6B]">{wine.data.points}</p>
        </div>
        <div class="hidden md:block w-px h-16 bg-[#FFE4E8]"></div>
        <div class="text-center">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-gray-400 mb-2">Værdi-Index</p>
          <p class="text-4xl font-black text-[#FF8E53]">{Number(wine.data.qpr).toFixed(2)}</p>
        </div>
      </div>
    </header>

    <div class="prose prose-xl prose-stone max-w-none mb-20 relative z-10 prose-headings:font-['Outfit'] prose-headings:font-bold prose-p:text-gray-600 prose-p:font-light leading-relaxed prose-strong:font-bold prose-strong:text-[#111827]">
      <Content />
    </div>

    <div class="relative z-10">
      <section class="max-w-4xl mx-auto">
        <ProConMatrix pros={wine.data.pros} cons={wine.data.cons} />
        
        <SonicSeasoning seed={wine.data.spotify_seed} />
      </section>
    </div>
  </article>
</Layout>
