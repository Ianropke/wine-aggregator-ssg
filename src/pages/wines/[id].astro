---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProConMatrix from '../../components/ProConMatrix.astro';
import VibeBadge from '../../components/VibeBadge.astro';

export async function getStaticPaths() {
  const wines = await getCollection('wines');
  return wines.map(wine => ({
    params: { id: wine.data.id },
    props: { wine },
  }));
}

const { wine } = Astro.props;
const { Content } = await render(wine);

// Bygger JSON-LD schema (Rule 10)
const schema = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": wine.data.title,
  "description": `Vinanmeldelse af ${wine.data.title} fra ${wine.data.region}. QPR: ${wine.data.qpr}.`,
  "offers": {
    "@type": "Offer",
    "priceCurrency": "DKK",
    "price": Math.round(wine.data.price),
    "availability": "https://schema.org/InStock"
  },
  "review": {
    "@type": "Review",
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": wine.data.points,
      "bestRating": 100
    },
    "author": {
      "@type": "Organization",
      "name": "VibeWine"
    }
  }
};
const pageDescription = `Vinanmeldelse og Vibe Score for ${wine.data.title} (${wine.data.vintage}) fra ${wine.data.region}. Vibe: ${wine.data.vibe_category || 'Kvalitetsvin'}. Score: ${wine.data.points}/100 pts.`;
---

<Layout title={`${wine.data.title} - VibeWine`} description={pageDescription} schema={schema}>
  <article class="max-w-4xl mx-auto bg-white rounded-[2rem] shadow-sm border border-[#FFE4E8] p-8 md:p-16 mb-16 relative overflow-hidden">
    <!-- Decorative gradient orb -->
    <div class="absolute -top-32 -right-32 w-64 h-64 bg-[#FF6B6B] rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>
    <div class="absolute -bottom-32 -left-32 w-64 h-64 bg-[#FF8E53] rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>

    <!-- The VibeBadge Sticker! -->
    <VibeBadge score={wine.data.points} class="absolute top-6 right-6 md:top-10 md:right-10 rotate-12 z-20" />

    <header class="text-center mb-16 relative z-10 pt-4 md:pt-0">
      <div class="flex items-center justify-center gap-3 text-sm font-bold uppercase tracking-widest text-[#FF6B6B] mb-6">
        <span>{wine.data.region}</span>
        <span class="w-1.5 h-1.5 rounded-full bg-[#FF6B6B] opacity-50"></span>
        <span>{wine.data.vintage}</span>
      </div>
      
      <h1 class="text-5xl md:text-7xl font-['Outfit',sans-serif] font-black text-[#111827] mb-12 leading-tight tracking-tight pr-0 md:pr-16">{wine.data.title}</h1>
      
      <div class="flex flex-col md:flex-row justify-between items-center gap-8 md:gap-12 bg-[#FFF9FA] p-8 md:p-12 rounded-3xl border border-[#FFE4E8]">
        <div class="flex-grow text-center md:text-left">
          <div class="prose prose-lg prose-stone prose-headings:font-['Outfit'] prose-headings:font-bold prose-p:text-[#111827] prose-p:font-medium prose-p:text-xl leading-relaxed">
            <Content />
          </div>
        </div>
        <div class="hidden md:block w-px h-24 bg-[#FFE4E8]"></div>
        <div class="flex flex-col gap-6 shrink-0">
          <div class="flex gap-8 md:gap-12 items-center justify-center">
            <div class="text-center">
              <p class="text-xs font-bold uppercase tracking-[0.2em] text-gray-400 mb-2">Pris</p>
              <p class="text-4xl font-black text-[#111827]">{Math.round(wine.data.price)} <span class="text-xl font-medium text-gray-500">kr.</span></p>
              {wine.data.bundle_size && wine.data.bundle_size > 1 && (
                <p class="text-sm font-medium text-gray-500 mt-1 uppercase tracking-wider text-[10px]">(ved køb af {wine.data.bundle_size} flasker)</p>
              )}
            </div>
            <div class="text-center">
              <p class="text-xs font-bold uppercase tracking-[0.2em] text-gray-400 mb-2">Værdi-Index</p>
              <p class="text-4xl font-black text-[#FF8E53]">{Number(wine.data.qpr).toFixed(2)}</p>
            </div>
          </div>
          {wine.data.buy_url && wine.data.retailer_name && (
            <a href={wine.data.buy_url} target="_blank" rel="noopener noreferrer" class="w-full text-center bg-[#FF6B6B] hover:bg-[#ff5252] text-white font-bold py-3 px-6 rounded-full transition-all duration-300 transform hover:-translate-y-1 hover:shadow-lg flex items-center justify-center gap-2">
              Køb hos {wine.data.retailer_name}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
                <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
              </svg>
            </a>
          )}
        </div>
      </div>
    </header>

    <div class="relative z-10">
      <section class="max-w-4xl mx-auto">
        <ProConMatrix pros={wine.data.pros} cons={wine.data.cons} />
      </section>
    </div>
  </article>
</Layout>
