---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProConMatrix from '../../components/ProConMatrix.astro';
import SonicSeasoning from '../../components/SonicSeasoning.astro';

export async function getStaticPaths() {
  const wines = await getCollection('wines');
  return wines.map(wine => ({
    params: { id: wine.data.id },
    props: { wine },
  }));
}

const { wine } = Astro.props;
const { Content } = await render(wine);

// Bygger JSON-LD schema (Rule 10)
const schema = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": wine.data.title,
  "description": `Vinanmeldelse af ${wine.data.title} fra ${wine.data.region}. QPR: ${wine.data.qpr}.`,
  "offers": {
    "@type": "Offer",
    "priceCurrency": "DKK",
    "price": wine.data.price,
    "availability": "https://schema.org/InStock"
  },
  "review": {
    "@type": "Review",
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": wine.data.points,
      "bestRating": 100,
      "worstRating": 50
    },
    "author": {
      "@type": "Organization",
      "name": "Wine Price Aggregator"
    },
    "positiveNotes": {
      "@type": "ItemList",
      "itemListElement": wine.data.pros.map((p: string, i: number) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": p
      }))
    },
    "negativeNotes": {
      "@type": "ItemList",
      "itemListElement": wine.data.cons.map((c: string, i: number) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": c
      }))
    }
  }
};
---

<Layout title={`${wine.data.title} | Wine Aggregator`} description={`Læs anmeldelsen af ${wine.data.title}.`} schema={schema}>
  <article class="prose prose-lg max-w-none prose-h2:mt-12 prose-h2:mb-4 prose-h2:text-3xl prose-h2:font-['Playfair_Display',serif] prose-h2:font-normal prose-h2:text-[#2C2A29] prose-p:text-gray-600 prose-p:font-light">
    <header class="mb-16 border-b border-[#E8E4D9] pb-10 text-center">
      <div class="flex justify-center flex-wrap gap-3 mb-6">
        <span class="text-[#722F37] text-sm uppercase tracking-widest font-bold">{wine.data.region}</span>
        <span class="text-gray-400 text-sm uppercase tracking-widest">|</span>
        <span class="text-gray-500 text-sm uppercase tracking-widest">Årgang {wine.data.vintage}</span>
      </div>
      <h1 class="text-4xl md:text-6xl font-['Playfair_Display',serif] font-normal text-[#2C2A29] mb-10 leading-tight">{wine.data.title}</h1>
      
      <div class="flex justify-center gap-12 items-center">
        <div class="text-center">
          <p class="text-xs text-gray-400 uppercase tracking-widest mb-2">Pris</p>
          <p class="text-3xl font-light text-[#2C2A29]">{Math.round(wine.data.price)} <span class="text-lg">kr.</span></p>
        </div>
        <div class="w-px h-10 bg-[#E8E4D9]"></div>
        <div class="text-center">
          <p class="text-xs text-gray-400 uppercase tracking-widest mb-2">Anbefaling</p>
          <p class="text-3xl font-['Playfair_Display',serif] italic text-[#722F37]">{wine.data.points}</p>
        </div>
        <div class="w-px h-10 bg-[#E8E4D9]"></div>
        <div class="text-center">
          <p class="text-xs text-gray-400 uppercase tracking-widest mb-2">Værdi-Index</p>
          <p class="text-3xl font-light text-emerald-700">{Number(wine.data.qpr).toFixed(2)}</p>
        </div>
      </div>
    </header>

    <Content />

    <ProConMatrix pros={wine.data.pros} cons={wine.data.cons} />
    
    <SonicSeasoning seed={wine.data.spotify_seed} />
  </article>
</Layout>
