---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allWines = await getCollection('wines');
// Filter for wines with a score of 95 or higher (feeling the vibe)
const hallOfFameWines = allWines
  .filter(wine => wine.data.points >= 95)
  .sort((a, b) => b.data.points - a.data.points)
  .slice(0, 12); // Limit to top 12 for the showcase
---

<Layout title="Hall of Fame 🔥 - VibeWine">
  <div class="mb-16 text-center max-w-2xl mx-auto">
    <div class="inline-block bg-[#FFF9FA] text-[#FF6B6B] px-6 py-2 rounded-full font-black tracking-[0.2em] uppercase mb-6 border border-[#FF6B6B]/20 shadow-sm">
      Feeling the Vibe
    </div>
    <h1 class="text-4xl md:text-6xl font-['Outfit',sans-serif] font-black text-[#111827] mb-6 tracking-tight">Hall of Fame</h1>
    <p class="text-xl text-gray-600 font-light leading-relaxed">
      Dette er eliten. De vine, der stikker helt af, og som leverer en overlegen, ubestridelig <span class="font-bold text-[#FF6B6B]">Vibe</span> lige nu. Hvis du vil have en sikker vinder til weekenden, så start her.
    </p>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-24">
    {hallOfFameWines.map((wine, index) => (
      <a href={`/wines/${wine.data.id}`} class="block group">
        <article class="bg-white p-6 rounded-3xl border-2 border-[#FF6B6B]/20 transition-all duration-300 hover:border-[#FF6B6B] hover:shadow-[0_20px_50px_-12px_rgba(255,107,107,0.3)] hover:-translate-y-2 flex flex-col h-full relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-[#FF6B6B] to-[#FF8E53]"></div>
          
          <div class="absolute top-4 right-4 bg-[#FF6B6B] text-white w-8 h-8 flex items-center justify-center rounded-full font-black text-sm shadow-md">
            #{index + 1}
          </div>

          <div class="mb-6 mt-4 flex-grow pr-8">
            <h2 class="text-2xl font-['Outfit',sans-serif] font-bold text-[#111827] mb-3 leading-tight group-hover:text-[#FF6B6B] transition-colors">{wine.data.title}</h2>
            <div class="flex flex-wrap items-center gap-2 text-xs text-gray-500 font-medium">
              <span class="bg-[#FFF9FA] px-2 py-1 rounded-full text-[#FF6B6B]">{wine.data.region}</span>
              <span>{wine.data.vintage}</span>
            </div>
          </div>
          
          <div class="flex justify-between items-end pt-4 border-t border-[#FFE4E8]">
            <div>
              <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-gray-400 mb-1">Pris</p>
              <p class="text-xl font-black text-[#111827]">{Math.round(wine.data.price)} <span class="text-xs font-medium text-gray-500">kr.</span></p>
              {wine.data.bundle_size && wine.data.bundle_size > 1 && (
                <p class="text-[10px] text-gray-400 uppercase tracking-widest mt-1">Ved {wine.data.bundle_size} flasker</p>
              )}
            </div>
            <div class="text-right">
              <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-[#FF6B6B] mb-1">Vibe Score</p>
              <p class="text-2xl font-['Outfit',sans-serif] font-black text-[#FF6B6B] drop-shadow-sm">{wine.data.points} <span class="text-xs font-medium text-gray-500">pts</span></p>
            </div>
          </div>
        </article>
      </a>
    ))}
  </div>
</Layout>
