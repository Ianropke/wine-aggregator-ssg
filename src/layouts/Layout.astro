---
import '../styles/global.css';
import VibeLogoBadge from '../components/VibeLogoBadge.astro';

interface Props {
  title: string;
  description?: string;
  schema?: any;
  maxWidth?: string;
}

const { title, description = "Wine Price Aggregator", schema, maxWidth = "max-w-4xl" } = Astro.props;
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL("/hero.jpg", Astro.url)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL("/hero.jpg", Astro.url)} />

    <!-- Canonical URL -->
    <link rel="canonical" href={Astro.url} />

    <!-- For AI Agents -->
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM-friendly text format" />

    <!-- Pagefind Search UI Styles -->
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Outfit:wght@400;700;900&display=swap" rel="stylesheet">
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
  </head>
  <body class="bg-[#FFF9FA] text-[#111827] font-['Inter',sans-serif] antialiased selection:bg-[#FF6B6B] selection:text-white">
    <header class="py-12 border-b border-[#FFE4E8]">
      <div class={`${maxWidth} mx-auto px-4 flex flex-col items-center justify-center text-center reveal`}>
        <a href="/" class="inline-block hover:scale-105 transition-transform duration-300">
          <VibeLogoBadge />
        </a>
        <nav class="mt-8 flex gap-6">
          <a href="/" class="text-sm font-bold text-gray-600 hover:text-[#FF6B6B] uppercase tracking-widest transition-colors bg-white px-5 py-2 rounded-full shadow-sm border border-[#FFE4E8]">Alle Vine</a>
          <a href="/hall-of-fame" class="text-sm font-bold text-[#FF6B6B] hover:text-white hover:bg-[#FF6B6B] bg-[#FFF9FA] uppercase tracking-widest transition-colors px-5 py-2 rounded-full shadow-sm border border-[#FF6B6B]/30 flex items-center gap-2">Hall of Fame <span class="text-lg leading-none">🔥</span></a>
        </nav>
      </div>
    </header>
    <main class={`${maxWidth} mx-auto px-4 py-12`} data-pagefind-body>
      <slot />
    </main>
    <footer class="py-16 text-center border-t border-[#FFE4E8] mt-12 bg-white">
      <p class="font-['Outfit',sans-serif] font-bold text-xl text-[#FF6B6B] mb-2">⚡️ VibeWine</p>
      <p class="font-['Inter',sans-serif] text-sm text-gray-400">Ingen terroir. Kun god energi.</p>
    </footer>
  </body>
</html>
