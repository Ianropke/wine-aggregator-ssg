---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  schema?: any;
}

const { title, description = "Wine Price Aggregator", schema } = Astro.props;
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Outfit:wght@400;700;900&display=swap" rel="stylesheet">
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
  </head>
  <body class="bg-[#FFF9FA] text-[#111827] font-['Inter',sans-serif] antialiased selection:bg-[#FF6B6B] selection:text-white">
    <header class="py-12 border-b border-[#FFE4E8]">
      <div class="max-w-4xl mx-auto px-4 flex flex-col items-center justify-center text-center">
        <a href="/" class="text-4xl md:text-5xl font-['Outfit',sans-serif] font-black tracking-tighter text-[#FF6B6B] uppercase">VibeWine</a>
        <p class="text-xs font-bold text-[#FF6B6B] uppercase tracking-[0.2em] mt-3">Drik Din Vibe</p>
      </div>
    </header>
    <main class="max-w-4xl mx-auto px-4 py-12" data-pagefind-body>
      <slot />
    </main>
    <footer class="py-16 text-center border-t border-[#FFE4E8] mt-12 bg-white">
      <p class="font-['Outfit',sans-serif] font-bold text-xl text-[#FF6B6B] mb-2">⚡️ VibeWine</p>
      <p class="font-['Inter',sans-serif] text-sm text-gray-400">Ingen terroir. Kun god energi.</p>
    </footer>
  </body>
</html>
