---
interface Props {
  score: number | string;
  class?: string;
}
const { score, class: className = "" } = Astro.props;
---

<div class={`relative inline-flex items-center justify-center transform hover:scale-105 transition-transform duration-300 ${className}`} title="Officiel VibeWine Score">
  <!-- Gradient background with drop shadow -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#FF6B6B] to-[#FF8E53] rounded-full shadow-[0_8px_20px_rgba(255,107,107,0.4)]"></div>
  
  <!-- Outer glowing ring -->
  <div class="absolute -inset-1 rounded-full border border-[#FF6B6B]/20"></div>
  
  <!-- Inner dotted border for that premium "certificated" look -->
  <div class="absolute inset-1.5 border border-white/40 border-dashed rounded-full"></div>
  
  <div class="relative flex flex-col items-center justify-center w-28 h-28 text-white rounded-full">
    <svg class="w-4 h-4 text-white/80 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg>
    <span class="text-[8px] font-bold uppercase tracking-[0.2em] leading-none mb-1 opacity-90">Officiel</span>
    <span class="text-4xl font-['Outfit'] font-black leading-none drop-shadow-md">{score}</span>
    <span class="text-[9px] font-bold uppercase tracking-[0.2em] leading-none mt-1 opacity-90">Vibe Score</span>
  </div>
</div>
