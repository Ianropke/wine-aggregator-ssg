---
interface Props {
  seed: string;
}
const { seed } = Astro.props;
---

<div class="bg-white border-2 border-[#FFE4E8] rounded-3xl p-8 my-12 text-center hover:border-[#FF6B6B] transition-colors duration-300">
  <h3 class="font-['Outfit'] mb-2 text-2xl text-[#111827] font-bold flex items-center justify-center gap-3">
    <svg class="w-6 h-6 text-[#FF6B6B]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"></path></svg>
    Den Musikalske Pairing
  </h3>
  <p class="text-gray-500 font-light mb-6 max-w-lg mx-auto">
    Vibe check: Sæt dette på anlægget, skænk et stort glas, og lad aftenen stikke helt af.
  </p>
  <div class="inline-flex items-center gap-4 bg-[#FFF9FA] border border-[#FFE4E8] rounded-full py-3 px-8 shadow-sm">
    <div class="text-center">
      <p class="text-[10px] text-[#FF6B6B] uppercase tracking-[0.2em] font-bold mb-1">Lyt til:</p>
      <p class="font-['Outfit'] font-medium text-lg text-[#111827]">{seed}</p>
    </div>
  </div>
</div>
