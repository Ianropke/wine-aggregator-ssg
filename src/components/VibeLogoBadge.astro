---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<div class={`relative inline-flex items-center justify-center transform hover:scale-105 transition-transform duration-300 ${className}`} title="VibeWine">
  <!-- Gradient background with drop shadow -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#FF6B6B] to-[#FF8E53] rounded-full shadow-[0_8px_20px_rgba(255,107,107,0.4)]"></div>
  
  <!-- Outer glowing ring -->
  <div class="absolute -inset-1 rounded-full border border-[#FF6B6B]/20"></div>
  
  <!-- Inner dotted border for that premium "certificated" look -->
  <div class="absolute inset-1.5 border border-white/40 border-dashed rounded-full"></div>
  
  <div class="relative flex flex-col items-center justify-center w-36 h-36 text-white rounded-full">
    <svg class="w-6 h-6 text-white/90 mb-1 drop-shadow-sm" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
    <span class="text-3xl font-['Outfit'] font-black leading-none drop-shadow-md tracking-tight">vibe</span>
    <span class="text-3xl font-['Outfit'] font-black leading-none drop-shadow-md tracking-tight">wine</span>
  </div>
</div>
