---
interface Props {
  pros: string[];
  cons: string[];
}
const { pros, cons } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-8 my-12">
  <div class="bg-[#FAF9F6] border border-[#E8E4D9] p-8">
    <h3 class="text-[#2C2A29] font-['Playfair_Display',serif] text-xl font-bold mb-4 flex items-center gap-2">
      <svg class="w-5 h-5 text-emerald-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"></path></svg>
      Vibe & Fordele
    </h3>
    <ul class="space-y-3">
      {pros.map(pro => (
        <li class="flex items-start gap-3 text-gray-600 font-light">
          <span class="text-emerald-700 mt-1">•</span>
          {pro}
        </li>
      ))}
    </ul>
  </div>

  <div class="bg-[#FAF9F6] border border-[#E8E4D9] p-8">
    <h3 class="text-[#2C2A29] font-['Playfair_Display',serif] text-xl font-bold mb-4 flex items-center gap-2">
      <svg class="w-5 h-5 text-[#722F37]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"></path></svg>
      Overvejelser
    </h3>
    <ul class="space-y-3">
      {cons.map(con => (
        <li class="flex items-start gap-3 text-gray-600 font-light">
          <span class="text-[#722F37] mt-1">•</span>
          {con}
        </li>
      ))}
    </ul>
  </div>
</div>
