---
interface Props {
  pros: string[];
  cons: string[];
}
const { pros, cons } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-4 my-8">
  <div class="bg-green-50/50 border border-green-200 p-6 rounded-xl">
    <h3 class="text-green-800 font-bold mb-4 flex items-center gap-2">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
      Fordele
    </h3>
    <ul class="space-y-2">
      {pros.map(pro => (
        <li class="flex items-start gap-2 text-green-900">
          <span class="text-green-500 mt-1">•</span>
          {pro}
        </li>
      ))}
    </ul>
  </div>

  <div class="bg-red-50/50 border border-red-200 p-6 rounded-xl">
    <h3 class="text-red-800 font-bold mb-4 flex items-center gap-2">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      Ulemper
    </h3>
    <ul class="space-y-2">
      {cons.map(con => (
        <li class="flex items-start gap-2 text-red-900">
          <span class="text-red-500 mt-1">•</span>
          {con}
        </li>
      ))}
    </ul>
  </div>
</div>
