---
interface Props {
  pros: string[];
  cons: string[];
}
const { pros, cons } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-8 my-12">
  <div class="bg-white border-2 border-[#FFE4E8] rounded-3xl p-8 hover:border-[#FF6B6B] transition-colors">
    <h3 class="text-[#111827] font-['Outfit',sans-serif] text-2xl font-bold mb-6 flex items-center gap-3">
      <div class="w-8 h-8 rounded-full bg-[#FFF9FA] flex items-center justify-center">
        <span class="text-[#FF6B6B] font-black text-lg">✓</span>
      </div>
      Vibe & Fordele
    </h3>
    <ul class="space-y-4">
      {pros.map(pro => (
        <li class="flex items-start gap-4 text-gray-600 font-medium">
          <span class="text-[#FF6B6B] mt-1 font-bold">•</span>
          {pro}
        </li>
      ))}
    </ul>
  </div>

  <div class="bg-white border-2 border-gray-100 rounded-3xl p-8 hover:border-gray-300 transition-colors">
    <h3 class="text-[#111827] font-['Outfit',sans-serif] text-2xl font-bold mb-6 flex items-center gap-3">
      <div class="w-8 h-8 rounded-full bg-gray-50 flex items-center justify-center">
        <span class="text-gray-400 font-black text-lg">✗</span>
      </div>
      Buzzkill
    </h3>
    <ul class="space-y-4">
      {cons.map(con => (
        <li class="flex items-start gap-4 text-gray-500 font-medium">
          <span class="text-gray-400 mt-1 font-bold">•</span>
          {con}
        </li>
      ))}
    </ul>
  </div>
</div>
